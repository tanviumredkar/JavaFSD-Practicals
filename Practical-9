#Create Database and Table

CREATE DATABASE testdb;

USE testdb;

CREATE TABLE student (
    id INT PRIMARY KEY,
    name VARCHAR(50)
);

INSERT INTO student VALUES (1, 'Rahul');
INSERT INTO student VALUES (2, 'Amit');

SELECT * FROM student;

#JDBC Program for SELECT
import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.ResultSet;
import java.sql.Statement;

public class JDBCDemo {

    public static void main(String[] args) {
        String url = "jdbc:mysql://localhost:3306/testdb";
        String user = "root";
        String password = "root";

        try {
            Connection con = DriverManager.getConnection(url, user, password);
            System.out.println("Connected to Database Successfully!");

            Statement stmt = con.createStatement(); // Step 2: Create Statement
            ResultSet rs = stmt.executeQuery("SELECT * FROM student"); // Step 3: Execute Query

            while (rs.next()) {
                System.out.println(
                    "ID: " + rs.getInt("id") +
                    ", Name: " + rs.getString("name")
                );
            }

            con.close();
        } catch (Exception e) {
            e.printStackTrace();
        }
    }
}

#JDBC Program for INSERT
import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;

public class InsertDemo {
    public static void main(String[] args) {
        try {
            Connection con = DriverManager.getConnection(
                "jdbc:mysql://localhost:3306/testdb", "root", "root"
            );

            String query = "INSERT INTO student (id, name) VALUES (?, ?)";
            PreparedStatement pst = con.prepareStatement(query);

            pst.setInt(1, 3);
            pst.setString(2, "Ravi");

            int rows = pst.executeUpdate();
            System.out.println(rows + " record inserted.");

            con.close();
        } catch (Exception e) {
            e.printStackTrace();
        }
    }
}

#JDBC Program for UPDATE
import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.PreparedStatement;

public class UpdateDemo {
    public static void main(String[] args) {
        try {
            Connection con = DriverManager.getConnection(
                "jdbc:mysql://localhost:3306/testdb", "root", "root"
            );

            String query = "UPDATE student SET name=? WHERE id=?";
            PreparedStatement pst = con.prepareStatement(query);

            pst.setString(1, "Amit");
            pst.setInt(2, 3);

            int rows = pst.executeUpdate();
            System.out.println(rows + " record updated.");

            con.close();
        } catch (Exception e) {
            e.printStackTrace();
        }
    }
}

